# Database
DATABASE_URL=postgresql://polychamp_user:@@CHAMP@@POLY@@123456:OK@localhost:5432/polychamp

# Polymarket (public endpoints, no key needed)
POLYMARKET_WS_URL=wss://clob.polymarket.com/ws/market
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# Server
NODE_ENV=production
PORT=55550
LOG_LEVEL=info
API_PASSWORD=mXjs3aWpw-xjlG9BApd1wuCcAMmFlCIP

##---- Collection

MIN_TRADE_USD=500
WS_RECONNECT_MAX_MS=30000
BALANCE_SNAPSHOT_TIMEOUT_MS=5000

#----- Feature flags

ENABLE_LIVE_TRADING=true
ENABLE_NOTIFICATIONS=false

#----- Trading Parameters

# Slippage tolerance (%) - Allow orders to fill at worse price to ensure execution
# Example: 3 = allow up to 3% price slippage (buy at up to 3% higher than current price)
# Recommended: 2-5% for illiquid markets, 1-2% for liquid markets

SLIPPAGE_TOLERANCE=3

#----- Telegram Notifications
#----- Get notified when positions open and close
#
# Setup instructions:
#   1. Create a bot: Message @BotFather on Telegram, send /newbot, follow prompts
#   2. Copy the bot token (looks like: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz)
#   3. Start your bot: Search for your bot on Telegram and click "Start"
#   4. Get your chat ID:
#      • Send a message to your bot
#      • Visit: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
#      • Find "chat":{"id":123456789} in the JSON response
#   5. Fill in the values below and test with: node src/notifications/test-telegram.js

TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

#----- Optional: Set your app's public URL (used in notification links)

BASE_URL=https://jeer.currenciary.com

#----- Polymarket auto-trader credentials (KEEP SECRET — never commit)
#----- Signer private key (for EIP-712 order signing)

POLY_SIGNER_KEY=YOUR_SIGNER_KEY

#----- L2 API credentials (HMAC auth)

POLY_API_KEY=YOUR_API_KEY
POLY_API_SECRET=YOUR_SECRET
POLY_API_PASSPHRASE=YOUR_PASSPHRASE
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137


#----- SPIKE TRADING

SPIKE_TRADING_MODE=PAPER

#----- Mean Reversion Tracker
# Set to 'true' to receive ntfy alerts when counter-spike token gains +20%, +40%, +80%
# Use this after manually entering a DOWN trade on a UP spike (or UP trade on DOWN spike)
REVERSION_TRACKING=false
SPIKE_STARTING_CAPITAL=1000

SPIKE_POSITION_SIZE_PCT=5
SPIKE_HYBRID_MODE=true

#----- RESIDENTIAL PROXY (for CLOB API only - bypasses Cloudflare 403)
#----- Smart routing: Only order placement uses proxy, market data goes direct
#----- Provider: IPRoyal (allows crypto trading, $7/GB)
#----- Traffic usage: ~0.028 GB/month = $0.20/month

# Enable proxy for CLOB API (set to 'false' to disable)

CLOB_USE_PROXY=true

# Proxy protocol: http or socks5 (IPRoyal uses HTTP)

CLOB_PROXY_PROTOCOL=http

# IPRoyal residential proxy credentials
# Country targeting format: password_country-XX (where XX = 2-letter country code)
# Polymarket-allowed countries: ES, PT, SE, NO, DK, CH, BR, JP, KR, CA, NZ
# Blocked by Polymarket: US, UK, FR, DE, IT, NL, BE, AU (see docs.polymarket.com/api-reference/geoblock)

CLOB_PROXY_HOST=geo.iproyal.com
CLOB_PROXY_PORT=12321
CLOB_PROXY_USER=luF2mGMKWROK1rxD
CLOB_PROXY_PASS=YOUR_PROXY_PASS

# Global proxy environment variables (DISABLED - proxy not needed, was causing 402 errors)
# HTTP_PROXY=http://luF2mGMKWROK1rxD:lFVeG05x4CoGfhlR_country-ES@geo.iproyal.com:12321
# HTTPS_PROXY=http://luF2mGMKWROK1rxD:lFVeG05x4CoGfhlR_country-ES@geo.iproyal.com:12321

# Desktop notifications via ntfy.sh
# Pick any unique topic name (keep it secret to avoid spam)
# Setup: open https://ntfy.sh/<your-topic> in Windows Chrome → Allow notifications

NTFY_TOPIC=

#----- Kalshi (optional — for cross-platform spike price logging)
#----- Get API key: kalshi.com → Settings → API Keys → Create key
#----- Store the downloaded private key PEM file at the path below
#
# KALSHI_API_KEY=your-key-id-here
# KALSHI_PRIVATE_KEY_FILE=/var/www/jeer.currenciary.com/polychamp/backend/kalshi-key.pem
#
# Alternatively, paste the PEM content inline (replace newlines with \n):
# KALSHI_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----


